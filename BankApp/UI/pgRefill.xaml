<Page x:Class="BankApp.UI.pgRefill"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BankApp.UI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Пополнение счёта">
    <StackPanel>
        <TextBlock x:Name="tbkMyBills">Выберите счёт</TextBlock>
        <ComboBox x:Name="cbxMyBills" SelectionChanged="cbxMyBills_SelectionChanged"></ComboBox>
        
        <TextBlock x:Name="tbkBalance" Visibility="Collapsed">Баланс:</TextBlock>
        
        <TextBlock>Введите сумму пополнения</TextBlock>
        <TextBox x:Name="tbSum"></TextBox>
        
        <Button x:Name="btnNext" IsEnabled="{Binding ElementName=tbxSum, Path=Text}" Click="btnNext_Click">Далее</Button>
    </StackPanel>
</Page>
